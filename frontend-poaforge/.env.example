# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Pinata IPFS Configuration
VITE_PINATA_JWT=your_pinata_jwt_token_here

# POAP Auto-Claim (optional): Address of the backend signer. Must match POAP_CLAIM_SIGNER_PRIVATE_KEY in Supabase Edge Function secrets.
# When set, creators can enable auto-claim (requires_approval=false) and attendees mint when they fulfill location/claim code.
# VITE_POAP_CLAIM_SIGNER_ADDRESS=0x...
