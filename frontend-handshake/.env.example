# Optional: Gitcoin Passport API key for GitHub attestation badge (server-side only).
# Set in Vercel (or host) env as PASSPORT_API_KEY. If unset, hasGitHub is false.
# PASSPORT_API_KEY=

# Optional: Allowed origins for embed postMessage (comma-separated).
# Build-time: VITE_ALLOWED_EMBED_ORIGINS=https://app.example.com,https://other.example.com
