# Ohana Protocol — keep private, do not commit
# Copy to .env and fill in your keys

# Private key format: 0x followed by 64 hex characters (32 bytes)
# No spaces, no quotes. Same format for all keys below.

# LUKSO / Universal Profile — used for LUKSO mainnet (42) and LUKSO testnet (4201)
# Needs LYX for gas
LUKSO_PRIVATE_KEY=0x

# Base — used for Base mainnet (8453) and Base Sepolia (84532)
# Needs ETH for gas
BASE_PRIVATE_KEY=0x

# Fallback: single key for all networks (if same wallet for LUKSO + Base)
# PRIVATE_KEY=0x

# Optional: custom RPC URLs
# LUKSO_RPC_URL=https://rpc.mainnet.lukso.network
# BASE_RPC_URL=https://mainnet.base.org
# ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Optional: fee collector address (defaults to deployer)
# FEE_COLLECTOR=0x

# Optional: Handshake proxy address (for setHandshakeFee script)
# HANDSHAKE_PROXY_ADDRESS=0x

# Optional: WalletConnect project ID (frontend works without it)
# VITE_WALLETCONNECT_PROJECT_ID=
